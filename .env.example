# Mock switch: set to true to use local mock services
VITE_USE_MOCK_API=false

# Mock-only settings
# VITE_MOCK_MODE=store | protocol (effective only when VITE_USE_MOCK_API=true)
VITE_MOCK_MODE=store
# Disable required-plugin gate in mock mode (set false to re-enable gate testing)
VITE_MOCK_DISABLE_REQUIRED_GATE=true
VITE_MOCK_LATENCY_MS=120
VITE_MOCK_SERVER_SOCKET=mock://handshake

# Local plugin dev source: load plugins/voice-call/dist directly (dev only)
# Set to true to have the host treat voice-call as a locally-built plugin served from /plugins/voice-call/
VITE_USE_LOCAL_VOICE_CALL_PLUGIN=false
