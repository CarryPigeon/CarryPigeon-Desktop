{
    "name": "carrypigeon-desktop",
    "private": true,
    "version": "0.3.0",
    "type": "module",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "esbuild"
        ]
    },
    "scripts": {
        "dev": "vite",
        "typecheck": "vue-tsc --noEmit",
        "build": "npm run -s typecheck && vite build",
        "preview": "vite preview",
        "tauri": "tauri",
        "lint": "npm run -s typecheck && npm run -s lint:logs:std && npm run -s lint:rust:std && npm run -s lint:feature:boundaries && npm run -s lint:docs",
        "lint:feature:boundaries": "bash scripts/check-feature-boundaries.sh",
        "lint:docs": "node scripts/check-markup-style-docs.mjs",
        "lint:rust:std": "bash scripts/check-rust-standards.sh",
        "lint:logs:std": "bash scripts/check-log-standards.sh",
        "test": "vitest run",
        "test:watch": "vitest",
        "benchmark": "bash scripts/perf-benchmark.sh"
    },
    "dependencies": {
        "@tanstack/vue-virtual": "^3.13.28",
        "@tauri-apps/api": "^2.11.0",
        "@tauri-apps/plugin-notification": "^2.3.3",
        "@tauri-apps/plugin-opener": "^2.5.4",
        "crypto-js": "^4.2.0",
        "emoji-picker-element": "^1.29.1",
        "tdesign-vue-next": "^1.18.0",
        "vue": "^3.5.26"
    },
    "devDependencies": {
        "@popperjs/core": "^2.11.8",
        "@tauri-apps/cli": "^2.11.2",
        "@tdesign-vue-next/auto-import-resolver": "^0.1.4",
        "@types/crypto-js": "^4.2.2",
        "@types/node": "^26.0.0",
        "@vitejs/plugin-vue": "^6.0.3",
        "@vitest/coverage-v8": "^4.1.9",
        "esbuild": "^0.28.1",
        "jsdom": "^29.1.1",
        "sass": "^1.97.2",
        "typescript": "~6.0.3",
        "typescript-language-server": "^5.3.0",
        "unplugin-auto-import": "^21.0.0",
        "unplugin-vue-components": "^32.1.0",
        "vite": "^8.0.16",
        "vitest": "^4.1.9",
        "vue-i18n": "^11.2.8",
        "vue-router": "^5.1.0",
        "vue-tsc": "^3.3.5"
    }
}
