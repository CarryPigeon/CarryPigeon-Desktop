{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "carrypigeon-desktop",
  "version": "0.3.0",
  "identifier": "com.carrypigeon-desktop.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "carrypigeon-desktop",
        "resizable": true,
        "width": 1200,
        "height": 800,
        "minHeight": 400,
        "minWidth": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' app:",
        "script-src": "'self' app:",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' app: data: blob: https:",
        "font-src": "'self' data:",
        "connect-src": "'self' https: wss: app:",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ShirasawaTopaz/carrypigeon-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
