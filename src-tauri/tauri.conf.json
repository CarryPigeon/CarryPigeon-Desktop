{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "carrypigeon-desktop",
  "version": "0.1.1",
  "identifier": "com.carrypigeon-desktop.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "carrypigeon-desktop",
        "resizable": true,
        "width": 800,
        "height": 600,
        "minHeight": 300,
        "minWidth": 400
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' app:",
        "script-src": "'self' app: 'unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' app: data: blob: http: https:",
        "font-src": "'self' data:",
        "connect-src": "'self' http: https: ws: wss: app:",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
